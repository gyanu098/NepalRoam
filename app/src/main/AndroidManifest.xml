<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyRoamNepal">
        <activity
            android:name=".view.SplashScreen"
            android:exported="true"
            android:label="@string/title_activity_splash_screen"
            android:theme="@style/Theme.MyRoamNepal">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".view.LoginActivity"
            android:exported="true"
            android:label="@string/title_activity_login"
            android:theme="@style/Theme.MyRoamNepal"></activity>
        <activity
            android:name=".view.RegistrationActivity"
            android:exported="false"
            android:label="Registration"
            android:theme="@style/Theme.MyRoamNepal"></activity>
        <activity
            android:name=".view.DashboardActivity"
            android:exported="true"
            android:label="@string/title_activity_dashboard"
            android:theme="@style/Theme.MyRoamNepal"></activity>
        <activity
            android:name=".view.AddPlaceActivity"
            android:exported="true"
            android:label="Add Place"
            android:theme="@style/Theme.MyRoamNepal"></activity>
        <activity
            android:name=".view.PlaceDetailActivity"
            android:exported="true"
            android:label="Place Details"
            android:theme="@style/Theme.MyRoamNepal"></activity>
        <activity
            android:name=".view.ReviewActivity"
            android:exported="true"
            android:label="Reviews"
            android:theme="@style/Theme.MyRoamNepal"></activity>
        <activity
            android:name=".view.ProfileActivity"
            android:exported="true"
            android:label="Profile"
            android:theme="@style/Theme.MyRoamNepal"></activity>
        <activity
            android:name=".view.NotificationActivity"
            android:exported="true"
            android:label="Notifications"
            android:theme="@style/Theme.MyRoamNepal"></activity>
        <activity
            android:name=".view.EditProfileActivity"
            android:exported="true"
            android:label="Edit Profile"
            android:theme="@style/Theme.MyRoamNepal"></activity>
        <activity
            android:name=".view.MyProfileActivity"
            android:exported="true"
            android:label="My Profile"
            android:theme="@style/Theme.MyRoamNepal"></activity>
        <activity
            android:name=".view.FavoritesActivity"
            android:exported="true"
            android:label="Favorites"
            android:theme="@style/Theme.MyRoamNepal"></activity>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MyRoamNepal"></activity>
    </application>

</manifest>